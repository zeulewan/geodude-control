title: |md
  # GEO-DUDe Power & Signal Overview
  12V System - Subscale Servicer Satellite
| {
  near: top-center
  shape: text
  style.font-size: 22
}

direction: right
# === AC PATH ===
wall: Wall Outlet\n120V AC {
  shape: page
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
iec: IEC C16\nPanel Socket {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
fuse_ac: 6A Fuse\n(slow-blow) {
  shape: diamond
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-size: 12
}
slip: Slip Ring\n3-wire 15A {
  shape: hexagon
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}

wall -> iec -> fuse_ac -> slip: {style.stroke: "#C62828"; style.stroke-width: 2}

# === PSU ===
psu: 12V 600W PSU\n50A max {
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.font-size: 14
}
slip -> psu: AC mains {style.stroke: "#C62828"; style.stroke-width: 2}

# === DC BUS ===
fuse_main: 30A Main\nDC Fuse {
  shape: diamond
  style.fill: "#BBDEFB"
  style.stroke: "#1565C0"
}
bus: 12V DC Bus\n(Wago) {
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
psu -> fuse_main -> bus: 10 AWG {style.stroke: "#1565C0"; style.stroke-width: 2}

# === ALWAYS-ON PATH (before relay) ===
always_on: Always-On Path (before relay) {
  style.fill: "#E8F5E9"
  style.stroke: "#43A047"
  style.border-radius: 8

  fuse_b2: 3A Fuse {
    shape: diamond
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    style.font-size: 11
  }
  buck2: Buck Conv 2\n12V -> 5V {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  pi: Raspberry Pi {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
  }

  fuse_b2 -> buck2 -> pi: 5V {style.stroke: "#43A047"}
}
bus -> always_on.fuse_b2: 18 AWG {style.stroke: "#1565C0"}

# === RELAY ===
relay: 40A Relay\n(Pi GPIO controlled)\nNormally Open {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
}
bus -> relay: 10 AWG {style.stroke: "#1565C0"; style.stroke-width: 2}
always_on.pi -> relay: GPIO enable {style.stroke: "#7B1FA2"; style.stroke-dash: 3}

# === PCA9685 (signal hub, powered from always-on 5V) ===
pca: PCA9685\nPWM Driver {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
always_on.buck2 -> pca: 5V logic {style.stroke: "#43A047"}
always_on.pi -> pca: I2C (GPIO 2+3) {style.stroke: "#7B1FA2"}

# === FUSE BLOCK (after relay) ===
fuse_block: Cyrico 12-Circuit Fuse Block {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.border-radius: 8

  base: Base Servos\n2x 150kg @ 12V {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  shoulder: Shoulder Servos\n2x 150kg @ 12V {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  buck1: Buck Conv 1\n12V -> 7.4V {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  elbow: Elbow Servos\n2x 80kg @ 7.4V {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  buck3: Buck Conv 3\n12V -> 5V {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }
  wrist: Wrist Servos\n4x RDS3218 @ 5V {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }
  ee: End-Effector\n4x MG90S @ 5V {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }
  fan: 12V Fan {
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#78909C"
  }

  buck1 -> elbow: 7.4V {style.stroke: "#2E7D32"}
  buck3 -> wrist: 5V {style.stroke: "#43A047"}
  buck3 -> ee: 5V {style.stroke: "#43A047"}
}
relay -> fuse_block: 10 AWG {style.stroke: "#1565C0"; style.stroke-width: 2}

# === PCA SIGNAL LINES ===
pca -> fuse_block.base: Ch 0-1 {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
pca -> fuse_block.shoulder: Ch 2-3 {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
pca -> fuse_block.elbow: Ch 4-5 {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
pca -> fuse_block.wrist: Ch 6-9 {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
pca -> fuse_block.ee: Ch 10-13 {style.stroke: "#7B1FA2"; style.stroke-dash: 3}

# === GND ===
gnd: GND Bus (Wago, star topology) {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#78909C"
  style.font-size: 12
}
psu -> gnd: 10 AWG {style.stroke: "#78909C"}
