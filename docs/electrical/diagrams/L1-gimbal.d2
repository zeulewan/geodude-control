title: |md
  # Gimbal Apparatus Overview
  24V System - 3-Axis Gimbal + Linear Rail
| {
  near: top-center
  shape: text
  style.font-size: 22
}

direction: right
# === MAINS ===
wall: Wall Outlet\n120V AC {
  shape: page
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}

# === 24V SYSTEM ===
power: 24V Power {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.border-radius: 8

  psu: 24V 480W PSU\n20A max {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
    style.stroke-width: 2
  }
  fuse: 12A Main Fuse {
    shape: diamond
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  bus: 24V Bus\n(Wago) {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
    style.stroke-width: 2
  }

  psu -> fuse -> bus: 14 AWG {style.stroke: "#EF6C00"}
}

wall -> power.psu: 120V AC {style.stroke: "#C62828"; style.stroke-width: 2}

# === CONTROLLER ===
controller: Controller {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 8

  usb: 5V USB\nAdapter {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }
  esp32: ESP32\nDOIT DevKit V1 {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
  }

  usb -> esp32: 5V USB {style.stroke: "#43A047"}
}

# === STEPPER DRIVERS ===
drivers: "TMC2209 Stepper Drivers - Breadboard" {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.border-radius: 8

  drv1: "TMC2209 #1\nAddr 0 - Yaw" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  drv2: "TMC2209 #2\nAddr 1 - Pitch" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  drv3: "TMC2209 #3\nAddr 2 - Roll" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  drv4: "TMC2209 #4\nAddr 3 - Belt" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
}

# === STEPPER MOTORS ===
motors: NEMA 17 Stepper Motors {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.border-radius: 8

  m1: "Yaw Motor\nbase rotation" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  m2: "Pitch Motor\nthrust bearing" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  m3: "Roll Motor\nthrust bearing" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  m4: "Belt Motor\nlinear drive" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
}

# === FANS ===
fans: 4x 24V 80mm Fans {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#78909C"
}

# === WIFI ===
wifi: WiFi Link\nto Raspberry Pi {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}

# === POWER CONNECTIONS ===
power.bus -> drivers.drv1: VMOT 24V {style.stroke: "#EF6C00"}
power.bus -> drivers.drv2: VMOT 24V {style.stroke: "#EF6C00"}
power.bus -> drivers.drv3: VMOT 24V {style.stroke: "#EF6C00"}
power.bus -> drivers.drv4: VMOT 24V {style.stroke: "#EF6C00"}
power.bus -> fans: 24V {style.stroke: "#EF6C00"}

# === SIGNAL CONNECTIONS ===
controller.esp32 -> drivers.drv1: GPIO 13/14\nSTEP/DIR {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
controller.esp32 -> drivers.drv2: GPIO 16/17\nSTEP/DIR {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
controller.esp32 -> drivers.drv3: GPIO 18/19\nSTEP/DIR {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
controller.esp32 -> drivers.drv4: GPIO 25/26\nSTEP/DIR {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
controller.esp32 -> drivers: UART bus\n(shared, 1k bridge) {style.stroke: "#7B1FA2"; style.stroke-dash: 3}

# === MOTOR CONNECTIONS ===
drivers.drv1 -> motors.m1: coil A/B {style.stroke: "#EF6C00"}
drivers.drv2 -> motors.m2: coil A/B {style.stroke: "#EF6C00"}
drivers.drv3 -> motors.m3: coil A/B {style.stroke: "#EF6C00"}
drivers.drv4 -> motors.m4: coil A/B {style.stroke: "#EF6C00"}

# === LOGIC POWER ===
controller.esp32 -> drivers: VIO 3.3V {style.stroke: "#43A047"; style.stroke-dash: 5}

# === WIFI ===
controller.esp32 -> wifi {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
