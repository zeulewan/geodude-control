title: |md
  # Subscale Satellite Test Setup
  AER813 Capstone - Full System Overview
| {
  near: top-center
  shape: text
  style.font-size: 24
}

direction: right

# --- Gimbal ---
gimbal: "Gimbal Apparatus (24V) | ESP32 + 4x TMC2209 + 4x NEMA 17 | Yaw, Pitch, Roll, Belt" {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.stroke-width: 3
  style.border-radius: 12
}

# --- Linear Rails ---
rails: "Linear Rail System | HGR15 1000mm + Belt Drive" {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#78909C"
  style.stroke-width: 2
  style.border-radius: 8
}

# --- GEO-DUDe ---
geodude: "GEO-DUDe Servicer (12V) | Pi + PCA9685 + Pi Camera | 2 arms (10 servos) + MACE reaction wheel | 10 limit switches" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 3
  style.border-radius: 12
}

# --- Base Station ---
basestation: "Base Station | Raspberry Pi + Laptop (Operator UI)" {
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  style.stroke-width: 3
  style.border-radius: 12
}

# --- Physical connections ---
gimbal -> rails: "gimbal mounts on" {style.stroke: "#78909C"; style.stroke-dash: 5}
rails -> geodude: "GEO-DUDe travels along" {style.stroke: "#78909C"; style.stroke-dash: 5}

# --- WiFi ---
gimbal <-> geodude: "WiFi" {style.stroke: "#7B1FA2"; style.stroke-width: 2; style.stroke-dash: 3}
basestation <-> gimbal: "WiFi" {style.stroke: "#AD1457"; style.stroke-width: 2; style.stroke-dash: 3}
basestation <-> geodude: "WiFi" {style.stroke: "#AD1457"; style.stroke-width: 2; style.stroke-dash: 3}
