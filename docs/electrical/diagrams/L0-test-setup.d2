title: |md
  # Subscale Satellite Test Setup
  Full system overview - AER813 Capstone
| {
  near: top-center
  shape: text
  style.font-size: 24
}

direction: right

# --- Gimbal System (left) ---
gimbal: Gimbal Apparatus - 24V System {
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.stroke-width: 3
  style.border-radius: 12
  style.font-color: "#E65100"

  wall: Wall Outlet 1\n120V AC {
    shape: page
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.font-color: "#B71C1C"
  }
  psu: 24V 480W PSU {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  busbar: V+ Bus Bar {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  perfboard: Gimbal Perfboard {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  steppers: 4x NEMA 17 Steppers\nYaw / Pitch / Roll / Belt {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#EF6C00"
  }
  usb: 5V USB Adapter\n(separate outlet) {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
  }

  wall -> psu: 120V AC {style.stroke: "#C62828"; style.stroke-width: 2}
  psu -> busbar: 14 AWG {style.stroke: "#EF6C00"}
  busbar -> perfboard: 24V VMOT {style.stroke: "#EF6C00"}
  usb -> perfboard: 5V barrel jack {style.stroke: "#43A047"}
  perfboard -> steppers: JST-XH {style.stroke: "#EF6C00"}
}

# --- Linear Rails (middle) ---
rails: Linear Rail System\nHGR15 1000mm\n+ Belt Drive {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#78909C"
  style.stroke-width: 2
  style.border-radius: 8
}

gimbal -> rails: gimbal\nmounts on {
  style.stroke: "#78909C"
  style.stroke-dash: 5
}

# --- GEO-DUDe System (right) ---
geodude: GEO-DUDe Servicer - 12V System {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 3
  style.border-radius: 12
  style.font-color: "#0D47A1"

  wall: Wall Outlet 2\n120V AC {
    shape: page
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.font-color: "#B71C1C"
  }
  slip: 3-Wire 15A\nSlip Ring {
    shape: hexagon
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  psu: 12V 600W PSU {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  busbar: V+ Bus Bar {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  pi: Raspberry Pi\n+ PCA9685 PWM {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  fuse_boards: Arm Fuse Boards (x2)\n10 servos, 2 arms {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  mace: MACE Reaction Wheel\nX2807 BLDC + 40A ESC {
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  camera: Pi Camera {
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#78909C"
  }
  limits: 10x Limit Switches {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#EF6C00"
  }

  wall -> slip: 120V AC {style.stroke: "#C62828"; style.stroke-width: 2}
  slip -> psu: AC passthrough {style.stroke: "#C62828"}
  psu -> busbar: 16 AWG {style.stroke: "#1565C0"}
  busbar -> pi: 5V (buck 2, always on) {style.stroke: "#43A047"}
  busbar -> fuse_boards: 40A fuse + toggle {style.stroke: "#1565C0"}
  busbar -> mace: 12 AWG (direct, no fuse) {style.stroke: "#3949AB"}
  pi -> fuse_boards: PWM + I2C {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
  pi -> mace: PWM + I2C {style.stroke: "#7B1FA2"; style.stroke-dash: 3}
  pi -> camera: CSI {style.stroke: "#78909C"}
  pi -> limits: GPIO {style.stroke: "#EF6C00"; style.stroke-dash: 3}
}

rails -> geodude: GEO-DUDe\ntravels along {
  style.stroke: "#78909C"
  style.stroke-dash: 5
}

# --- Base Station (below, centered) ---
basestation: Base Station (Ground Control) {
  style.fill: "#FCE4EC"
  style.stroke: "#AD1457"
  style.stroke-width: 3
  style.border-radius: 12
  style.font-color: "#880E4F"

  laptop: Laptop\n(Operator UI) {
    shape: rectangle
    style.fill: "#F8BBD0"
    style.stroke: "#AD1457"
  }
  pi: Raspberry Pi\n(Ground Control) {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }

  laptop -> pi: USB / Ethernet {style.stroke: "#AD1457"}
}

# --- WiFi links ---
gimbal.perfboard <-> geodude.pi: WiFi\ncoordinated operation {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  style.stroke-dash: 3
}
basestation.pi <-> gimbal.perfboard: WiFi {
  style.stroke: "#AD1457"
  style.stroke-width: 2
  style.stroke-dash: 3
}
basestation.pi <-> geodude.pi: WiFi {
  style.stroke: "#AD1457"
  style.stroke-width: 2
  style.stroke-dash: 3
}
