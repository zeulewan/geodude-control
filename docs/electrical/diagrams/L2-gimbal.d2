direction: right

title: |md
  # Gimbal Apparatus - 24V System
  3-Axis Gimbal + Linear Rail
| {
  near: top-center
  shape: text
  style.font-size: 20
}

# === PSU ===
wall: "Wall Outlet (120V AC)" {shape: page; style.fill: "#FFCDD2"; style.stroke: "#C62828"}
psu: "24V 480W PSU (20A max)" {shape: rectangle; style.fill: "#FFE0B2"; style.stroke: "#EF6C00"; style.stroke-width: 2}
busbar: "V+ Bus Bar (250A, 5/16\" stud)" {shape: rectangle; style.fill: "#FFE0B2"; style.stroke: "#EF6C00"; style.stroke-width: 2}

wall -> psu: "120V AC" {style.stroke: "#C62828"; style.stroke-width: 2}
psu -> busbar: "14 AWG (no fuse, TMC2209 + PSU protected)" {style.stroke: "#EF6C00"; style.stroke-width: 2}

# === ESP32 (separate 5V USB power) ===
usb: "5V USB Adapter" {shape: rectangle; style.fill: "#E8F5E9"; style.stroke: "#43A047"}
esp32: "ESP32 DOIT DevKit V1" {shape: rectangle; style.fill: "#F3E5F5"; style.stroke: "#7B1FA2"; style.stroke-width: 2}

usb -> esp32: "5V USB" {style.stroke: "#43A047"}

# === 4x TMC2209 DRIVERS ===
drivers: "4x TMC2209 Stepper Drivers | UART addressed | 2A RMS each | breadboard for logic" {
  shape: rectangle
  style.fill: "#FFE0B2"
  style.stroke: "#EF6C00"
  style.stroke-width: 2
  style.border-radius: 8
}

# === 4x NEMA 17 MOTORS ===
motors: "4x NEMA 17 Steppers | Yaw, Pitch, Roll, Belt | 6-to-4 pin cables" {
  shape: rectangle
  style.fill: "#FFE0B2"
  style.stroke: "#EF6C00"
  style.stroke-width: 2
  style.border-radius: 8
}

drivers -> motors: "coil A/B (6-to-4 pin, 1M)" {style.stroke: "#EF6C00"}

# === DECOUPLING CAPS ===
caps: "4x Decoupling Caps | 100uF 50V + 100nF ceramic per VMOT" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-size: 11
}

# === FANS ===
fans: "4x 24V 80mm Fans (~0.6A total)" {shape: rectangle; style.fill: "#ECEFF1"; style.stroke: "#78909C"}

# === POWER: Bus bar to stepper bank ===
busbar -> drivers: "18 AWG each (VMOT, ring terminals to bus bar)" {style.stroke: "#EF6C00"; style.stroke-width: 2}
busbar -> fans: "22 AWG" {style.stroke: "#78909C"}
busbar -> caps: "across VMOT/GND" {style.stroke: "#C62828"; style.stroke-dash: 3}

# === SIGNAL: ESP32 to stepper bank ===
esp32 -> drivers: "STEP/DIR (4 pairs) + UART shared bus (1k bridge) + 3.3V VIO" {style.stroke: "#7B1FA2"; style.stroke-dash: 3}

# === WIFI ===
wifi: "WiFi Link to Raspberry Pi" {shape: rectangle; style.fill: "#F3E5F5"; style.stroke: "#7B1FA2"; style.stroke-dash: 3}
esp32 -> wifi {style.stroke: "#7B1FA2"; style.stroke-dash: 5}

# === GND ===
gnd: "GND Bus Bar (250A, 5/16\" stud) | PSU GND -> 14 AWG -> bus bar | 18 AWG to each driver GND" {
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  style.stroke-width: 2
  near: bottom-center
}
