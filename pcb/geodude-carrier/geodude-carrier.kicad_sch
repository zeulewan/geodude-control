  (text "DESIGN NOTES:"
    (at 500 340 0)
    (effects
      (font
        (size 2.54 2.54)
      )
    )
    (uuid "fb6a07ba-015d-4758-8ff4-992f8b3b6b08")
  )
  (text "1. PCA9685 VCC = 3.3V (from Pi 3.3V pin)"
    (at 500 352 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "aea07c63-59ab-43d5-9d81-41fc87b0142a")
  )
  (text "2. PCA9685 OE tied to GND = always enabled"
    (at 500 362 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "5f6b4239-d1d7-440d-aeb0-aad28f103c13")
  )
  (text "3. I2C bus (SDA/SCL) shared: PCA9685 + 4 breakout terminals"
    (at 500 372 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "15b5e9bf-a478-4578-9b38-71af24b89fac")
  )
  (text "4. 12V servos (SV1,SV2,SV6,SV7) fused at 8A"
    (at 500 382 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "ee960f87-5c71-4582-8151-e0a7da7c8f50")
  )
  (text "5. 7.4V servos (SV3,SV8) fused at 5A"
    (at 500 392 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "b511c017-0428-4035-b16c-cb9c116c8a96")
  )
  (text "6. 5V_SERVO wrist servos (SV4,SV5,SV9,SV10) fused at 3A (from buck converter 3)"
    (at 500 402 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "d314e150-e527-47cc-aa16-07de448bffca")
  )
  (text "7. ESC (Ch11) and FAN (Ch12) on 12V direct, no fuse"
    (at 500 412 0)
    (effects
      (font
        (size 1.8 1.8)
      )
    )
    (uuid "45111f4b-3408-4e44-876a-ccdd015828e7")
  )
  (text "8. All servo GND pins share common ground"
    (at 500 422 0)
    (effects
      (font
        (size 1.8 1.8)
