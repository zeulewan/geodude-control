(footprint "BLX-A_5x20mm"
  (version 20240108)
  (generator "custom")
  (layer "F.Cu")
  (descr "BLX-A PCB mount 5x20mm fuse holder, 28x10x18mm body, pin spacing ~24mm (VERIFY WITH CALIPERS)")
  (tags "fuse holder 5x20mm BLX-A PCB mount")
  (attr through_hole)
  (fp_text reference "REF**" (at 0 -8) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value "BLX-A_5x20mm" (at 0 8) (layer "F.Fab")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start -14 -5) (end 14 -5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 14 -5) (end 14 5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 14 5) (end -14 5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -14 5) (end -14 -5) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -16 -7) (end 16 -7) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start 16 -7) (end 16 7) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start 16 7) (end -16 7) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start -16 7) (end -16 -7) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (pad "1" thru_hole circle (at -12 0) (size 3.0 3.0) (drill 1.8) (layers "*.Cu" "*.Mask")
    (net 0 ""))
  (pad "2" thru_hole circle (at 12 0) (size 3.0 3.0) (drill 1.8) (layers "*.Cu" "*.Mask")
    (net 0 ""))
)
